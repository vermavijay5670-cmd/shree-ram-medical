# --- Database (Supabase-hosted Postgres) ---
# Get this from Supabase → Project Settings → Database → Connection string
DATABASE_URL="postgresql://user:password@host:5432/postgres?schema=public"

# --- NextAuth ---
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-byte-secret"
AUTH_URL="http://localhost:3000"

# --- Cloudinary (medicine images, company logos, gallery) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
